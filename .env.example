# Copy to .env and fill in values from:
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Zone for scripts and curl examples (find via scripts/list_zones.py)
CLOUDFLARE_ZONE_NAME=your-test-domain.example.com
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Custom WAF ruleset for http_request_firewall_custom (Security > WAF > Custom rules > API)
CLOUDFLARE_CUSTOM_RULESET_ID=your_custom_ruleset_id_here
